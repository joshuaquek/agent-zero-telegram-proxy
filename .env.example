# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Agent Zero internal URL (default works with the docker-compose setup)
AGENT_ZERO_URL=http://agent-zero:80

# Agent Zero API key (find in Agent Zero UI → Settings → External Services)
AGENT_ZERO_API_KEY=

# Agent Zero web UI credentials (needed for streaming via WebSocket)
# These are the same credentials you use to log into the Agent Zero web UI
AGENT_ZERO_LOGIN=admin
AGENT_ZERO_PASSWORD=

# Comma-separated Telegram user IDs allowed to use the bot
# Leave empty to allow everyone (not recommended)
# To find your user ID, message @userinfobot on Telegram
ALLOWED_TELEGRAM_USER_IDS=

# Timeout in seconds for Agent Zero API calls (default: 120)
REQUEST_TIMEOUT_SECONDS=120

# Minimum interval between draft updates in milliseconds (default: 200)
# Lower = smoother streaming, higher = fewer API calls
DRAFT_THROTTLE_MS=200
